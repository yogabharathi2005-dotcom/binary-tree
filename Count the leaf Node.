import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int arr[]=new int[n];
        for(int i=0;i<n;i++){
            arr[i]=sc.nextInt();
        }
            Node root=new Node(arr[0]);
            Queue<Node>q=new LinkedList<>();
            q.offer(root);
            int i=1;
            while(i<n){
                Node t=q.poll();
                if(arr[i]!=-1){
                    t.left=new Node(arr[i]);
                    q.offer(t.left);
                }
                i++;
                if(arr[i]!=-1){
                    t.right=new Node(arr[i]);
                    q.offer(t.right);
                }
                i++;
            }
            System.out.println(leaf(root));
        }
        public static int leaf(Node root){
            if(root==null) 
            return 0;
            if(root.left==null&&root.right==null)
            return 1;
            return leaf(root.left)+leaf(root.right);
        }
    }
    class Node{
        int data;
        Node left;
        Node right;
        Node(int data){
            this.data=data;
            left=null;
            right=null;
        }
    }
